# ===== 채점용 Anthropic API =====
ANTHROPIC_API_KEY=sk-ant-여기에-키
# 선택: 채점 모델 (기본 claude-sonnet-4-6)
GRADER_MODEL=claude-sonnet-4-6

# ===== 구글 드라이브 업로드(교수 계정) =====
GOOGLE_CLIENT_ID=여기에-클라이언트-ID
GOOGLE_CLIENT_SECRET=여기에-클라이언트-시크릿
GOOGLE_REFRESH_TOKEN=여기에-리프레시-토큰
# 결과를 모아둘 드라이브 폴더 ID (폴더 URL 끝의 문자열)
GOOGLE_DRIVE_FOLDER_ID=여기에-폴더-ID

# 선택: 한글 폰트 TTF URL (기본값 있음, 보통 그대로 둬도 됨)
# KR_FONT_URL=https://cdn.jsdelivr.net/npm/@expo-google-fonts/noto-sans-kr/NotoSansKR_400Regular.ttf
